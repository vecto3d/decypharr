# Decypharr Environment Configuration
# Place .env in your data/config folder or the working directory.
# Environment variables override config.json values.

# ──────────────────────────────────────────────
# Real-Debrid API Key
# Get yours at: https://real-debrid.com/apitoken
# ──────────────────────────────────────────────
RD_API_KEY=your_api_key_here

# ──────────────────────────────────────────────
# Paths
# ──────────────────────────────────────────────

# Where symlinks (and local files after caching) are stored
# Arr apps (Sonarr/Radarr) should point to this folder
# Subfolders are created per category (e.g. /mnt/media/sonarr, /mnt/media/radarr)
DOWNLOAD_FOLDER=/mnt/media

# Rclone mount path where debrid files are accessible
# Symlinks will point to files under this path
RCLONE_MOUNT_PATH=/mnt/remote

# ──────────────────────────────────────────────
# Local Cache
# When enabled, symlinks are replaced with real local files
# immediately after creation (no waiting for a scan interval)
# ──────────────────────────────────────────────
LOCAL_CACHE_ENABLED=true

# Substring in symlink target that identifies rclone mounts
RCLONE_INDICATOR=decypharr/realdebrid

# Seconds between background scans for missed symlinks
SCAN_INTERVAL=1800

# Stop downloading when free space drops below this (MB)
MIN_FREE_MB=20000

# Remove stale .part files older than this many hours
STALE_HOURS=24

# Max simultaneous file copies
MAX_PARALLEL=2

# Try to download directly from debrid CDN (faster than FUSE copy)
USE_DEBRID_CDN=true

# Parallel connections per CDN download (requires aria2c)
ARIA2_CONNECTIONS=16

# ──────────────────────────────────────────────
# Other
# ──────────────────────────────────────────────
DECYPHARR_SECRET_KEY=677bae921b9878f0abc2cf69170b85d32624c7c11deb3cb55ef91a84180a5299
UMASK=002
